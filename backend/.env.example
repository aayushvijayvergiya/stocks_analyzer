# ==============================================
# STOCKS ANALYZER BACKEND - ENVIRONMENT VARIABLES
# ==============================================

# ----------------------------------------------
# LLM Configuration
# ----------------------------------------------
# Primary LLM provider: "groq" or "openai"
LLM_PROVIDER=groq

# Groq API Configuration (Free tier - Recommended for development)
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI API Configuration (Fallback)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ----------------------------------------------
# Redis Configuration
# ----------------------------------------------
# Redis connection URL (default for local development)
REDIS_URL=redis://localhost:6379
# For Docker: redis://redis:6379

# Cache TTL settings (in seconds)
CACHE_TTL_STOCKS=1800
CACHE_TTL_FUNDS=1800
CACHE_TTL_CHAT=300

# ----------------------------------------------
# API Configuration
# ----------------------------------------------
# Application environment: development, staging, production
ENVIRONMENT=development

# API settings
API_V1_PREFIX=/api/v1

# CORS settings (JSON array format)
# For development: ["http://localhost:3000","http://localhost:5173"]
# For production: ["https://yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ----------------------------------------------
# CrewAI Configuration
# ----------------------------------------------
# Crew execution timeout (in seconds)
CREW_TIMEOUT_SECONDS=90

# Enable/disable crew features
ENABLE_CREW_MEMORY=true
ENABLE_CREW_CACHE=true

# ----------------------------------------------
# Rate Limiting
# ----------------------------------------------
# Rate limit: X requests per Y seconds
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ----------------------------------------------
# External APIs (Optional)
# ----------------------------------------------
# NewsAPI (Optional - 100 requests/day free)
# Get your API key at: https://newsapi.org/
NEWSAPI_KEY=

# Serper API for Google Search (Optional - 2500 searches/month free)
# Get your API key at: https://serper.dev/
SERPER_API_KEY=

# ----------------------------------------------
# Model Configuration (Legacy - for backward compatibility)
# ----------------------------------------------
MODEL=groq/llama-3.1-70b-versatile
